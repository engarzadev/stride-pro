# Database
DATABASE_URL=postgres://user:password@localhost:5432/stridepro?sslmode=disable

# Server
PORT=8080
ENVIRONMENT=dev

# Authentication
# Must be at least 32 characters. Generate one with: openssl rand -base64 32
JWT_SECRET=replace-this-with-a-random-32-char-secret!!

# CORS — comma-separated list of allowed frontend origins
# Development: http://localhost:4200
# Production:  https://app.yourdomain.com
ALLOWED_ORIGINS=http://localhost:4200

# HTTPS — one of the two options below must be configured in production.
#
# Option A: Direct TLS — the server holds the certificate and terminates TLS itself.
# An HTTP→HTTPS redirect server will automatically start on HTTP_PORT (default 80).
TLS_CERT_FILE=
TLS_KEY_FILE=
HTTP_PORT=80
#
# Option B: Proxy mode — TLS is terminated upstream (AWS ALB, Cloudflare, nginx, etc.).
# The server trusts the X-Forwarded-Proto header and redirects plain HTTP requests.
TLS_PROXY_MODE=false

# SendGrid (for email notifications)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=you@yourdomain.com
SENDGRID_FROM_NAME=Stride Pro

# Twilio (for SMS notifications - v2)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
