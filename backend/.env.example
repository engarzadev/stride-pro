# Database
DATABASE_URL=postgres://user:password@localhost:5432/stridepro?sslmode=disable

# Server
PORT=8080
ENVIRONMENT=dev

# Authentication
JWT_SECRET=your-secret-key-change-in-production

# SendGrid (for email notifications)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=you@yourdomain.com
SENDGRID_FROM_NAME=Stride Pro

# Twilio (for SMS notifications - v2)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
